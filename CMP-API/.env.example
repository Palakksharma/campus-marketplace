# Campus Marketplace Backend Configuration
# Port for Express server
PORT=3000

# MongoDB Database URI (e.g. mongodb+srv://...)
MONGO_URL=

# JWT Secret key for signing authorization tokens
JWT_SECRET=

# Cloudinary credentials for media upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_API_KEY=
CLOUDINARY_CLOUD_API_SECRET=

# Frontend URLs allowed by CORS (comma-separated list for multiple urls)
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175
